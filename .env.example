# =============================================================================
# .env.example — TravelPlanner Environment Variables
# =============================================================================
# Copy this file to .env and fill in your actual values.
# .env is git-ignored — never commit real keys.
# =============================================================================


# ── LLM Provider Keys ────────────────────────────────────────────────────────

# OpenAI
OPENAI_API_KEY=sk-...
OPENAI_ORG_ID=      # optional

# OpenRouter (primary provider for team credits)
OPENROUTER_API_KEY=sk-or-...
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Groq
GROQ_API_KEY=gsk_...
GROQ_BASE_URL=https://api.groq.com/openai/v1

# Ollama (cloud or local)
# IMPORTANT: Do NOT append /v1 — use the root endpoint:
#   Local:  OLLAMA_BASE_URL=http://localhost:11434
#   Cloud:  OLLAMA_BASE_URL=https://ollama.com
OLLAMA_BASE_URL=https://ollama.com
OLLAMA_API_KEY=      # required for cloud endpoints


# ── External Service APIs ────────────────────────────────────────────────────

# LiteAPI (Hotel Search)
# Get your test token from: https://app.liteapi.travel
LITEAPI_API_KEY=

# Google Places API (New) — Restaurant Search
# Get one at: https://developers.google.com/maps/documentation/places/web-service/cloud-setup
GOOGLE_PLACES_API_KEY=

# Tavily — General Web Search retrieval
# Get one at: https://tavily.com
TAVILY_API_KEY=

# SerpAPI — Attraction Search
# Get one at: https://serpapi.com
SERPAPI_API_KEY=


# ── Agent Tuning & Optional Overrides ────────────────────────────────────────
#
# All keys below have sensible defaults baked into the code.
# Uncomment and set only if you want to override defaults.
#

# Global defaults
# TRAVELPLANNER_MODEL=openrouter:anthropic/claude-3.5-sonnet
# TRAVELPLANNER_TEMPERATURE=0.0

# Config file paths
# TRAVELPLANNER_GLOBAL_CONFIG_PATH=./config.yaml
# TRAVELPLANNER_LOCAL_CONFIG_PATH=./local.config.yaml

# ── Itinerary Validation ──────────────────────────────────────────────────────
# Maximum number of attempts the itinerary validator may retry before forcing END.
# Default: 3
# TRAVELPLANNER_MAX_VALIDATION_RETRIES=3

# ── Restaurant Search Agent ──────────────────────────────────────────────────
# TRAVELPLANNER_RESTAURANT_TIMEOUT_SECONDS=30
# TRAVELPLANNER_RESTAURANT_MAX_RESULTS=5

# ── Flight Search Agent ──────────────────────────────────────────────────────
# TRAVELPLANNER_FLIGHT_DEFAULT_ADULTS=1
# TRAVELPLANNER_FLIGHT_TIMEOUT_SECONDS=30
# TRAVELPLANNER_FLIGHT_MAX_RESULTS=10

# ── Attraction Search Agent ─────────────────────────────────────────────────
# TRAVELPLANNER_ATTRACTION_EMBEDDING_MODEL=text-embedding-3-small
# TRAVELPLANNER_ATTRACTION_MODEL=gpt-4o-mini
# TRAVELPLANNER_ATTRACTION_TEMPERATURE=0.0
# TRAVELPLANNER_ATTRACTION_MAX_CANDIDATES=20
# TRAVELPLANNER_ATTRACTION_TOP_REVIEW_CANDIDATES=10
# TRAVELPLANNER_ATTRACTION_TIMEOUT_SECONDS=30

# ── General Web Search Agent ────────────────────────────────────────────────
# TRAVELPLANNER_GENERAL_WEB_SEARCH_MAX_RESULTS=10
# TRAVELPLANNER_GENERAL_WEB_SEARCH_TIMEOUT_SECONDS=30
# TRAVELPLANNER_GENERAL_WEB_SEARCH_MAX_RETRIES=3
# TRAVELPLANNER_GENERAL_WEB_SEARCH_MAX_SEARCHES=3
# TRAVELPLANNER_GENERAL_WEB_SEARCH_INCLUDE_ANSWER=true
# TRAVELPLANNER_GENERAL_WEB_SEARCH_EXTRACT_MAX_SOURCES=5
# TRAVELPLANNER_GENERAL_WEB_SEARCH_EXTRACT_TIMEOUT=30
