
# Example env vars for TravelPlanner.
# Export them in your shell or load them with your tooling.

# OpenAI
OPENAI_API_KEY=
OPENAI_ORG_ID=

# OpenRouter
OPENROUTER_API_KEY=
# Optional base URL override.
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Groq
GROQ_API_KEY=
# Optional base URL override.
GROQ_BASE_URL=https://api.groq.com/openai/v1

# Ollama
# Default local OpenAI-compatible endpoint.
OLLAMA_BASE_URL=http://localhost:11434/v1
# Optional; Ollama usually does not require a real key.
OLLAMA_API_KEY=

# Not used by the code yet.
# Model selection is still passed as model_name in Python.
# TRAVELPLANNER_MODEL=openrouter:anthropic/claude-3.7-sonnet
# TRAVELPLANNER_TEMPERATURE=0.0
